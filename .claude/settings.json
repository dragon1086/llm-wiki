{
  "enableAllProjectMcpServers": true,
  "env": {
    "CLAUDE_AUTOCOMPACT_PCT_OVERRIDE": "80"
  },
  "permissions": {
    "allow": [
      "Bash(source .venv/bin/activate*)",
      "Bash(python3 scripts/wiki.py *)",
      "Bash(python3 scripts/*.py *)",
      "Bash(cat *)",
      "Bash(ls *)",
      "Bash(find *)",
      "Edit(*)",
      "Write(*)",
      "Read(*)",
      "mcp__obsidian__*",
      "Bash(./wiki *)"
    ],
    "deny": [],
    "ask": [
      "Bash(rm *)",
      "Bash(pip *)",
      "Bash(pip3 *)"
    ]
  },
  "plansDirectory": "./tasks"
}