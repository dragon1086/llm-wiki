#!/usr/bin/env bash
# LLM Wiki — 간편 실행 래퍼
# venv 활성화 없이 어디서든 실행 가능:
#   ./wiki query "트랜스포머 어텐션이 왜 O(n²)인가?"
#   ./wiki ingest --all
#   ./wiki lint --fix
#
# 전역 명령으로 쓰고 싶다면:
#   echo 'alias wiki="/Users/aerok/Desktop/rocky/llm-wiki/wiki"' >> ~/.zshrc

REPO_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"

if [ ! -f "$REPO_DIR/.venv/bin/activate" ]; then
  echo "오류: .venv가 없습니다. 먼저 'python3 -m venv .venv && pip install -r requirements.txt' 실행 후 재시도하세요." >&2
  exit 1
fi

source "$REPO_DIR/.venv/bin/activate"
python3 "$REPO_DIR/scripts/wiki.py" "$@"
